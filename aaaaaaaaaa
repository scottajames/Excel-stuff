// Convert column letter → number (A=0, B=1, etc.)
function colLetterToIndex(letter) {
    return letter.toUpperCase().charCodeAt(0) - 65;
}

// Get column values until the first empty cell
function getColumnUntilEmpty(rows, colLetter) {
    const colIndex = colLetterToIndex(colLetter);
    const values = [];

    for (let i = 0; i < rows.length; i++) {
        const cellValue = rows[i][colIndex];

        if (cellValue === undefined || cellValue === null || cellValue === "") {
            break; // stop when empty
        }

        values.push(cellValue);
    }

    return values;
}
